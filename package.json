{
  "name": "omni-ide",
  "version": "1.0.0",
  "description": "Premium AI Coding IDE with GitHub integration",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@octokit/rest": "^20.1.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.5.3",
    "axios": "^1.18.1",
    "compression": "^1.7.4",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "lucide-react": "^1.24.0",
    "mime-types": "^2.1.35",
    "monaco-editor": "^0.55.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.4",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "postcss": "^8.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2",
    "uuid": "^10.0.0",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
