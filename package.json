{
  "name": "omni-ide",
  "version": "1.0.0",
  "description": "Premium AI Coding IDE with GitHub integration",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently --names \"EXPRESS,VITE\" --prefix-colors \"cyan,magenta\" \"nodemon server/index.js\" \"cd client && npm run dev\"",
    "server": "nodemon server/index.js",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.2",
    "compression": "^1.7.4",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.4",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  }
}
